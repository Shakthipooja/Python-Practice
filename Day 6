#Count the vowels in the string
text = input("Enter a string : ").lower()
count = 0
for ch in text:
    if ch in "aeiou":
        count+=1
print("Vowels =",count)

#Count consonents in the string
text = input("Enter a string: ").lower()
count=0
for ch in text:
    if ch.isalpha() and ch not in "aeiou":
             count +=1
print("consonents = ",count)

