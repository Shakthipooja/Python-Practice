#Count the number of odd and even
a=list(map(int,input("Enter the numbers in the list: ").split()))
even_count=0
odd_count=0
for num in a:
    if num % 2 ==0:
        even_count += 1
    else:
        odd_count += 1
print("Even = ",even_count)
print("Odd = ",odd_count)

