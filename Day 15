#Number is prime
number = int(input("Enter a number: "))
if number <=1:
    print("Not prime")
else:
    is_prime = True
    for i in range(2, number):
        if number % i == 0:
            is_prime = False
            break
    if is_prime:
        print("Prime number")
    else:
        print("Not a prime")
