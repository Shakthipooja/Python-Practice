#Hospital Management System
class Patient:
    def __init__(self,
                 patient_id,
                 name,
                 disease):
        self.patient_id = patient_id
        self.name = name
        self.disease = disease
    def display(self):
        print(
            self.patient_id,
            self.name,
            self.disease
        )
patients = []
def add_patient():
    patient_id = input(
        "Enter Patient ID: "
    )
    name = input(
        "Enter Name: "
    )
    disease = input(
        "Enter Disease: "
    )
    patient = Patient(
        patient_id,
        name,
        disease
    )
    patients.append(patient)
    print("Patient Added")
def display_patient():
    if len(patients) == 0:
        print("No Patients")
        return
    for patient in patients:
        patient.display()
def search_patient():
    search = input(
        "Enter Patient ID: "
    )
    for patient in patients:
        if patient.patient_id == search:
            patient.display()
            return
    print("Patient Not Found")
def delete_patient():
    delete = input(
        "Enter Patient ID: "
    )
    for patient in patients:
        if patient.patient_id == delete:
            patients.remove(patient)
            print(
                "Patient Deleted"
            )
            return
    print(
        "Patient Not Found"
    )
def save_patient():
    with open(
        "patients.txt",
        "w"
    ) as file:
        for patient in patients:
            file.write(
                f"{patient.patient_id},"
                f"{patient.name},"
                f"{patient.disease}\n"
            )
    print(
        "Saved Successfully"
    )
while True:
    print("\n1.Add Patient")
    print("2.Search Patient")
    print("3.Display Patient")
    print("4.Delete Patient")
    print("5.Save Patient")
    print("6.Exit")
    choice = int(
        input(
            "Enter choice: "
        )
    )
    if choice == 1:
        add_patient()
    elif choice == 2:
        search_patient()
    elif choice == 3:
        display_patient()
    elif choice == 4:
        delete_patient()
    elif choice == 5:
        save_patient()
    elif choice == 6:
        break
    else:
        print(
            "Invalid Choice"
        )
              
